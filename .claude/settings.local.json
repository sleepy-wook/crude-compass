{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/crude-compass/.claude/hooks/pre_tool_use_safety.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/crude-compass/.claude/hooks/post_tool_use_validate.py",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python C:/crude-compass/.claude/hooks/user_prompt_context.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
