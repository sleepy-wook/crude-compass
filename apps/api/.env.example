# Local dev — Databricks Apps prod auto-injects PG* vars
# Copy to .env and fill in for local Lakebase test (optional)

CRUDE_COMPASS_ENV=dev

# Lakebase Postgres (Apps 자동 주입; 로컬 dev에서만 수동 입력)
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGSSLMODE=require
PGAPPNAME=crude-compass-dev
DATABRICKS_LAKEBASE_INSTANCE=crude-compass-pg

# Databricks SDK (워크스페이스 인증)
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# External APIs
OILPRICEAPI_KEY=
AISSTREAM_KEY=
ECOS_KEY=

# Genie + AI/BI
GENIE_SPACE_ID=
AIBI_DASHBOARD_ID=
